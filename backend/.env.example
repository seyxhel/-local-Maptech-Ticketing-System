# Backend .env.example — copy to `.env` and customize

# Preferred: set full DATABASE_URL for Railway Postgres (no trailing slash)
# Example:
DATABASE_URL=postgres://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>

# Optional: fallback to sqlite when DATABASE_URL is not set
# DB_PATH=/app/data/db.sqlite3

# How long to wait (seconds) for the DB host:port to become reachable at startup
# Default used by entrypoint: 30
WAIT_FOR_DB_SECONDS=30

# Django settings
SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS
# Comma-separated origins (example: http://localhost:3000,https://example.com)
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=True

# CSRF trusted origins (required when frontend and API are on different domains)
# Example: https://app.example.com,https://admin.example.com
CSRF_TRUSTED_ORIGINS=

# JWT HttpOnly cookie settings
JWT_ACCESS_COOKIE_NAME=maptech_access
JWT_REFRESH_COOKIE_NAME=maptech_refresh
JWT_COOKIE_HTTPONLY=True
JWT_COOKIE_SECURE=True
# Use None for cross-site frontend/API deployments; requires HTTPS
JWT_COOKIE_SAMESITE=Lax
# Optional shared cookie domain, e.g. .example.com
JWT_COOKIE_DOMAIN=
JWT_COOKIE_PATH=/

# TLS/HTTP2 (optional). If you deploy Daphne to terminate TLS, set these to
# paths to the certificate and key files inside the container. On platforms
# that terminate TLS for you (Railway), leave these unset and let the
# platform handle certificates.
# SSL_CERT_FILE=/path/to/fullchain.pem
# SSL_KEY_FILE=/path/to/privkey.pem
# Enable HTTP/2 when Daphne is used for TLS
# ENABLE_HTTP2=False
p# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=*

# Database (default: SQLite — override for PostgreSQL/MySQL in production)
# DATABASE_URL=postgres://user:password@localhost:5432/ticketing_db

# CORS
CORS_ALLOW_ALL_ORIGINS=True
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
